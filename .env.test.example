# Copy to .env.test and fill in values.
# .env.test overrides and extends .env for e2e tests.
# Gitignored — never commit real tokens.

# Each must be a user who has joined GUILD_ID (from .env).
TESTER_PRIMARY_ID=
VOTER_A_ID=
VOTER_B_ID=
OFFICER_ID=

# Optional: override the default path. Defaults to ./tests/e2e/.data/test.db.
# TEST_DB_PATH=./tests/e2e/.data/test.db
