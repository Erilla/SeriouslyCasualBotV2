{
  "name": "seriouslycasual-bot-v2",
  "version": "1.0.0",
  "description": "World of Warcraft guild management Discord bot for SeriouslyCasual",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsx watch src/index.ts",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run --config vitest.live.config.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "@discordjs/rest": "^2.4.0",
    "discord-api-types": "^0.37.100",
    "better-sqlite3": "^11.6.0",
    "bullmq": "^5.25.0",
    "ioredis": "^5.4.1",
    "dotenv": "^16.4.5",
    "axios": "^1.7.7"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.9",
    "vitest": "^2.1.3",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0"
  }
}
